# MariaDB service configuration
DATABASE_NAME=fastapi_archetype
DATASOURCE_USER=archetype
DATASOURCE_PASSWORD=changeme

# Application database connection (must match MariaDB config above)
DB_DRIVER=mysql+pymysql
DB_HOST=mariadb
DB_PORT=3306
DB_USER=archetype
DB_PASSWORD=changeme
DB_NAME=fastapi_archetype

# Application settings
APP_NAME=fastapi-archetype
LOG_LEVEL=DEBUG
OTEL_EXPORT_ENABLED=true
OTEL_EXPORTER_ENDPOINT=http://otel-collector:4317

# Build context (relative to compose/ directory)
FASTAPI_ARCHETYPE_CONTEXT_PATH=..
FASTAPI_ARCHETYPE_DOCKERFILE_PATH=Dockerfile

# OTEL Collector image
OTELCOL_IMG=otel/opentelemetry-collector:latest
