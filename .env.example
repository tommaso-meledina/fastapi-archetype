# Application
APP_NAME=fastapi-archetype
DEBUG=false
# LOG_LEVEL=INFO             (default — DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_MODE=plain             (default — plain | json; invalid values fall back to plain)

# OpenTelemetry
# OTEL_EXPORT_ENABLED=false    (default — set true to export traces to collector)
# OTEL_EXPORTER_ENDPOINT=http://localhost:4317  (default — gRPC OTLP collector)
# OTEL_SERVICE_NAME=fastapi-archetype           (default — service.name resource attribute)

# Reverse proxy
# ROOT_PATH=               (default — empty; set to path prefix when behind a reverse proxy, e.g. /api/v1)

# Rate Limiting (slowapi — format: "N/period" where period is second, minute, hour, day)
# RATE_LIMIT_GET_DUMMIES=100/minute   (default — GET /v{n}/dummies)
# RATE_LIMIT_POST_DUMMIES=10/minute   (default — POST /v{n}/dummies)

# Database
# DB_DRIVER=sqlite          (default — in-memory, no setup needed)
# DB_DRIVER=mysql+pymysql   (MariaDB — requires a running instance)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=fastapi_archetype

# Authentication / Authorization
# AUTH_TYPE=none                       (default — none | entra)
# AUTH_EXTERNAL_ISSUER=                (required when AUTH_TYPE=entra)
# AUTH_EXTERNAL_AUDIENCE=              (optional; if empty, audience check is skipped)
# AUTH_EXTERNAL_DISCOVERY_URI=         (required unless AUTH_EXTERNAL_JWKS_URI is set)
# AUTH_EXTERNAL_JWKS_URI=              (required unless AUTH_EXTERNAL_DISCOVERY_URI is set)
# AUTH_EXTERNAL_TOKEN_URI=             (required when AUTH_TYPE=entra)
# AUTH_EXTERNAL_CLIENT_ID=             (required when AUTH_TYPE=entra)
# AUTH_EXTERNAL_CLIENT_SECRET=         (required when AUTH_TYPE=entra)
# AUTH_EXTERNAL_GRAPH_SCOPE=https://graph.microsoft.com/.default
# AUTH_EXTERNAL_GRAPH_ROLES_URI_TEMPLATE=https://graph.microsoft.com/v1.0/users/{user_id}/appRoleAssignments
#
# Auth outbound HTTP behavior
# AUTH_HTTP_TIMEOUT_SECONDS=10
# AUTH_HTTP_RETRY_ATTEMPTS=1
# AUTH_ENFORCE_GRAPH_ROLES=false
